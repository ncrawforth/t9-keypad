#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>

/ {
    keymap {
        compatible = "zmk,keymap";
        default_layer {
            bindings = <
                &kp N7       &kp N8       &kp N9
                &kp N4       &kp N5       &kp N6
                &kp N1       &kp N2       &kp N3
                &bt BT_CLR   &kp N0       &bt BT_SEL 0
            >;
        };
    };
};
